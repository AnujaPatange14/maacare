      "output": "single",
      "name": "MaaCare",
      "shortName": "MaaCare",
      "description": "Gentle routines for growing hearts — child habit tracking for parents",
      "themeColor": "#7C5CFC",
      "backgroundColor": "#FAFAFE"
    }
  }
}
